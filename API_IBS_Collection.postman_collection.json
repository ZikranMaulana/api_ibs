{
	"info": {
		"name": "API IBS - CRUD & Status Soft Delete",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Cabang",
			"item": [
				{
					"name": "Get All Cabang",
					"request": {
						"method": "GET",
						"header": [{"key": "Accept", "value": "application/json"}],
						"url": {
							"raw": "{{base_url}}/cabangs",
							"host": ["{{base_url}}"],
							"path": ["cabangs"]
						}
					}
				},
				{
					"name": "Create Cabang (Test Double Data)",
					"request": {
						"method": "POST",
						"header": [{"key": "Accept", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nama_cabang\": \"Cabang Utama Jakarta\",\n    \"lokasi\": \"Jakarta Selatan\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/cabangs",
							"host": ["{{base_url}}"],
							"path": ["cabangs"]
						}
					}
				},
				{
					"name": "Edit Cabang",
					"request": {
						"method": "PUT",
						"header": [{"key": "Accept", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nama_cabang\": \"Cabang Utama Jakarta Update\",\n    \"lokasi\": \"Jakarta Pusat\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{base_url}}/cabangs/1",
							"host": ["{{base_url}}"],
							"path": ["cabangs", "1"]
						}
					}
				},
				{
					"name": "Delete Cabang (Soft Delete)",
					"request": {
						"method": "DELETE",
						"header": [{"key": "Accept", "value": "application/json"}],
						"url": {
							"raw": "{{base_url}}/cabangs/1",
							"host": ["{{base_url}}"],
							"path": ["cabangs", "1"]
						}
					}
				}
			]
		},
